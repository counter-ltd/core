DATABASE_URL=postgresql://localhost:5432/counter
JWT_SECRET=
JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d
# 64-char hex key for AES-256-GCM at-rest encryption (emails, push tokens, OAuth tokens).
# Generate: openssl rand -hex 32
MESSAGE_ENCRYPTION_KEY=
# Separate 64-char hex key for blind indexes (email + push token lookups).
# Generate: openssl rand -hex 32
BLIND_INDEX_KEY=
S3_ENDPOINT=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_BUCKET=
PUBLIC_API_URL=http://localhost:3000
